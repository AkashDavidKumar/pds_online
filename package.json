{
  "name": "pds-system",
  "version": "1.0.0",
  "workspaces": [
    "pds-backend",
    "pds-web-frontend"
  ],
  "description": "Tamil Nadu Digital Public Distribution System (TNPDS) — Full Stack",
  "scripts": {
    "client": "npm run dev -w pds-web-frontend",
    "server": "npm run dev -w pds-backend",
    "build": "npm run build -w pds-web-frontend",
    "start": "node pds-backend/server.js",
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run server\" \"npm run client\"",
    "install:all": "npm install",
    "seed": "cd pds-backend && node seed.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["pds", "ration-system", "nodejs", "react", "mongodb"],
  "author": "Akash David Kumar",
  "license": "ISC"
}
