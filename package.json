{
  "name": "pds-system",
  "version": "1.0.0",
  "description": "Tamil Nadu Digital Public Distribution System (TNPDS) — Full Stack",
  "scripts": {
    "client": "cd pds-web-frontend && npm run dev",
    "server": "cd pds-backend && npm run dev",
    "build": "cd pds-web-frontend && npm run build",
    "start": "node pds-backend/server.js",
    "install:all": "npm install",
    "seed": "cd pds-backend && node seed.js",
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.3",
    "bcryptjs": "^2.4.3",
    "qrcode": "^1.5.4",
    "pdfkit": "^0.17.2",
    "json2csv": "^6.0.0-alpha.2"
  },
  "keywords": [
    "pds",
    "ration-system",
    "nodejs",
    "react",
    "mongodb"
  ],
  "author": "Akash David Kumar",
  "license": "MIT"
}
